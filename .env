HOST_SMTP_PORT=25

# Allowed source IP
ALLOWED_IP=192.168.X.X

# Provider configurations
PROVIDER1_NAME=provider1
PROVIDER1_URL=https://sms.provider1.com/api/Sms/Send
PROVIDER1_AUTH=Basic XXXXXXXXXXXXXXXX=

PROVIDER1_CONNECT_TIMEOUT=3
PROVIDER1_READ_TIMEOUT=7
PROVIDER1_MIN_TIMEOUT=1
PROVIDER1_MAX_TIMEOUT=10

PROVIDER2_NAME=provider2
PROVIDER2_URL=https://console.provider2.com/api/send/shared/xxxxxxxxxxxxxxxxxx
PROVIDER2_BODY_ID=1111111

PROVIDER2_CONNECT_TIMEOUT=3
PROVIDER2_READ_TIMEOUT=7
PROVIDER2_MIN_TIMEOUT=1
PROVIDER2_MAX_TIMEOUT=10

PROVIDER3_NAME=provider3
PROVIDER3_URL=https://api.provider3.com/api/v3.0.1/send
PROVIDER3_AUTH=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PROVIDER3_SRCNUM=XXXXXX

# Priority order (comma-separated provider names)
PROVIDER3_CONNECT_TIMEOUT=3
PROVIDER3_READ_TIMEOUT=7
PROVIDER3_RETRIES=0
PROVIDER3_MIN_TIMEOUT=1
PROVIDER3_MAX_TIMEOUT=10

PROVIDER_PRIORITY=provider1,provider2,provider3
